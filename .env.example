# =============================================================================
#  apex-bench .env  ---  copy to .env and fill in the keys you actually use.
#  Never commit .env. The .gitignore at repo root enforces this.
# =============================================================================

# --- Generation (test-model providers) --------------------------------------
# Set the key(s) for whichever provider(s) host the model(s) you want to test.
# You only need keys for providers you actually use.

# OpenAI — required for gpt-5.5-* test profiles AND for the judge (gpt-5.5).
# IMPORTANT: no leading/trailing whitespace around the `=`. python-dotenv
# will include any spaces in the value, which silently invalidates the key.
OPENAI_API_KEY=sk-...

# xAI — required for grok-4.3-* test profiles.
XAI_API_KEY=xai-...

# Anthropic direct API — NOT used by this project. Claude test profiles run
# via AWS Bedrock (see the AWS block below). Leave commented out unless you
# explicitly add a direct-API Claude profile.
# ANTHROPIC_API_KEY=sk-ant-...

# Google — NOT used. The project judge is gpt-5.5, not Gemini.
# GOOGLE_API_KEY=...

# --- AWS Bedrock (for claude-opus-4.6 / sonnet-4.6 / haiku-4.5 profiles) ----
# LiteLLM picks these up via boto3. The simplest setup is explicit access
# keys; `AWS_PROFILE` (pointing at ~/.aws/credentials) also works.
# Required for any `claude-*-thinking-*` test profile. Not needed if you only
# run gpt-5.5-* or grok-4.3-* profiles.
#
# Prereqs (one-time, in the AWS console — NOT in this file):
#   1. Request model access for `anthropic.claude-opus-4-6-v1` /
#      `anthropic.claude-sonnet-4-6-v1` / `anthropic.claude-haiku-4-5-20251001-v1`
#      in EVERY region the cross-region inference profile spans (for `us.`,
#      that's us-east-1, us-east-2, us-west-2 at minimum).
#   2. Check Service Quotas for Bedrock TPM/RPM in your region.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# --- Grading (judge) --------------------------------------------------------
# Project judge: gpt-5.5 at OpenAI's default reasoning_effort=medium.
# Reuses OPENAI_API_KEY above; no separate key needed.

# --- Document parsing (PDF/CSV/XLSX attachments) ----------------------------
# REQUIRED. Every public APEX task has at least one attachment, so the smoke
# AND any real run will fail without this set.
REDUCTO_API_KEY=...

# --- HuggingFace (dataset fetch) --------------------------------------------
# Optional. The mercor/APEX-v1-extended dataset is not gated, so anonymous
# access works. Set this only if you hit rate limits during dataset fetch.
# HF_TOKEN=hf_...
